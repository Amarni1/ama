# Frontend API base URL
# Local development example:
# VITE_API_URL=http://localhost:4000
#
# External deployed backend example:
# VITE_API_URL=https://your-backend.onrender.com
VITE_API_URL=

# Treasury-backed swap runtime
# Configure these on the backend service that runs `server/index.js`.
TREASURY_ADDRESS=
MINIMA_CHAIN_API_URL=
TREASURY_PAYOUT_URL=
TREASURY_PAYOUT_TOKEN=

# Token ids for treasury settlement.
# USDT has a known default in the app, but you can still override it here.
SWAP_TOKEN_ID_USDT=0x7E6E60E033C7F74400B02F270074D0DA99FB863C33F8EA75078219258DCFC6CE
SWAP_TOKEN_ID_USDC=
SWAP_TOKEN_ID_MA=
SWAP_TOKEN_ID_LUCOS=
SWAP_TOKEN_ID_GRETES=
